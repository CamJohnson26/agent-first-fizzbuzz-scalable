{
  "buildCommand": "cd ../.. && pnpm build --filter=@fizzbuzz/web-server",
  "installCommand": "cd ../.. && pnpm install",
  "devCommand": "pnpm dev",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "includeFiles": "../../packages/rust-fizzbuzz/dist/node/*.wasm"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "api/index.ts" }
  ]
}
