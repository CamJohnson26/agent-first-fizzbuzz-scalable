FROM node:24.14.1-slim AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN apt-get update && apt-get install -y \
    curl \
    gcc \
    libc6-dev \
    libgmp-dev \
    nginx \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*
RUN npm install -g corepack@latest --force && corepack enable

FROM base AS build
# Install Rust and Lean
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"
RUN curl https://rustwasm.github.io/wasm-pack/installer/init.sh -sSf | sh -s -- -y
RUN curl https://raw.githubusercontent.com/leanprover/elan/master/elan-init.sh -sSf | sh -s -- -y --default-toolchain none
ENV PATH="/root/.elan/bin:${PATH}"

WORKDIR /usr/src/app
COPY . .
RUN pnpm install --no-frozen-lockfile
RUN pnpm build

# Deploy backend services
RUN pnpm deploy --filter @fizzbuzz/web-server --prod /prod/web-server
RUN pnpm deploy --filter @fizzbuzz/analytics-service --prod /prod/analytics-service
RUN pnpm deploy --filter @fizzbuzz/lean-service --prod /prod/lean-service

FROM node:24.14.1-slim AS production
RUN apt-get update && apt-get install -y \
    libgmp10 \
    nginx \
    curl \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python requirements
COPY apps/fizzbuzz-transformer/requirements.txt /app/fizzbuzz-transformer/requirements.txt
RUN python3 -m venv /app/venv
RUN /app/venv/bin/pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

# Copy backends
COPY --from=build /prod/web-server /app/web-server
COPY --from=build /prod/analytics-service /app/analytics-service
COPY --from=build /prod/lean-service /app/lean-service

# Copy Python app
COPY apps/fizzbuzz-transformer /app/fizzbuzz-transformer

# Copy Lean binary
COPY --from=build /usr/src/app/packages/verified-algorithms/lean/.lake/build/bin/fizzbuzz /app/lean-service/bin/fizzbuzz
ENV LEAN_BINARY_PATH=/app/lean-service/bin/fizzbuzz

# Copy static apps
COPY --from=build /usr/src/app/apps/marketing-landing-page/dist /usr/share/nginx/html/marketing
COPY --from=build /usr/src/app/apps/web-dashboard/dist /usr/share/nginx/html/dashboard

# Copy v86 images for web-server
COPY --from=build /usr/src/app/apps/web-server/v86-images /app/web-server/v86-images

# Copy nginx config and start script
COPY infra/nginx.conf /app/nginx.conf
COPY scripts/start-monolith.sh /app/start-monolith.sh
RUN chmod +x /app/start-monolith.sh

# Environment variables for production
ENV NODE_ENV=production
ENV PYTHON_PATH=/app/venv/bin/python
ENV TRANSFORMER_PATH=/app/fizzbuzz-transformer
ENV TRANSFORMER_MODEL_PATH=/app/fizzbuzz-transformer/fizzbuzz_model.pt

EXPOSE 8080
CMD ["/app/start-monolith.sh"]
